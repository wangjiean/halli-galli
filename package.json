{
  "name": "halli-galli",
  "version": "1.0.0",
  "description": "德国心脏病新增版 - LAN multiplayer card game",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "test": "npx playwright test",
    "test:auth": "npx playwright test halli-galli-auth",
    "test:rooms": "npx playwright test halli-galli-rooms",
    "test:gameplay": "npx playwright test halli-galli-gameplay",
    "test:bell": "npx playwright test halli-galli-bell",
    "test:leaderboard": "npx playwright test halli-galli-leaderboard",
    "test:all": "npx playwright test halli-galli"
  },
  "keywords": [
    "halli-galli",
    "card-game",
    "multiplayer",
    "reaction-game"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "lowdb": "^7.0.1",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^8.2.0"
  }
}
